{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./app/*"],
      "@markazi/ui": ["../../packages/ui/src"],
      "@markazi/db": ["../../packages/db/src"],
      "@markazi/auth": ["../../packages/auth/src"],
      "@markazi/api": ["../../packages/api/src"]
    },
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
