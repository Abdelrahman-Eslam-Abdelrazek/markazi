# ============================================================
# Markazi — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=مركزي

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL — for Prisma)
DATABASE_URL="postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Auth (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMS / OTP (Infobip)
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SENDER=

# WhatsApp Business API (Meta Cloud API / 360dialog)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="مركزي <noreply@markazi.com>"

# Payments (Paymob)
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_FAWRY=
PAYMOB_INTEGRATION_ID_VODAFONE=
PAYMOB_IFRAME_ID=

# Video Streaming (Mux)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Zoom (Live Sessions)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
